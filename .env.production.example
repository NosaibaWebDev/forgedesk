# ForgeDesk Studio - Production Environment
# Copy to .env and fill in your values

APP_NAME="ForgeDesk Studio"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://forgedesk.example.com
APP_LOCALE=he
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database - choose one driver and uncomment
DB_CONNECTION=mysql
# DB_CONNECTION=pgsql
# DB_CONNECTION=sqlite

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=forgedesk
DB_USERNAME=forgedesk
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD_HERE

# PostgreSQL (uncomment to use)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=forgedesk
# DB_USERNAME=forgedesk
# DB_PASSWORD=YOUR_SECURE_DB_PASSWORD_HERE

# Cache & Session - use Redis in production
CACHE_STORE=file
SESSION_DRIVER=file
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Queue
QUEUE_CONNECTION=database

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=YOUR_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@forgedesk.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Filesystem
FILESYSTEM_DISK=local
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# Security
APP_KEY=YOUR_APP_KEY_HERE  # Generate with: php artisan key:generate --show
SESSION_ENCRYPT=true
SANCTUM_STATEFUL_DOMAINS=forgedesk.example.com
SESSION_DOMAIN=.forgedesk.example.com
SESSION_SECURE_COOKIE=true
